<Page x:Class="LittleLauncher.Pages.LauncherItemsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:pages="using:LittleLauncher.Pages"
      xmlns:win="using:LittleLauncher.Windows">

    <Page.Resources>
        <win:IconPathToImageConverter x:Key="IconPathToImage" />
        <win:IconPathToVisibilityConverter x:Key="IconPathToVisibility" />

        <!-- Template for regular launcher items -->
        <DataTemplate x:Key="LauncherItemTemplate">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,2"
                    Loaded="ItemCard_Loaded"
                    PointerEntered="ItemCard_PointerEntered" PointerExited="ItemCard_PointerExited">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE700;" FontSize="12" Opacity="0.3" VerticalAlignment="Center"
                              ToolTipService.ToolTip="Drag to reorder"/>
                    <Grid Grid.Column="1" Width="24" Height="24" VerticalAlignment="Center">
                        <Image Source="{Binding IconPath, Converter={StaticResource IconPathToImage}}"
                               Visibility="{Binding IconPath, Converter={StaticResource IconPathToVisibility}}"
                               Width="24" Height="24" />
                        <FontIcon Glyph="{Binding IconGlyph}"
                                  Visibility="{Binding IconPath, Converter={StaticResource IconPathToVisibility}, ConverterParameter=invert}"
                                  FontSize="20" />
                    </Grid>
                    <TextBlock Grid.Column="2" Text="{Binding Name}" FontWeight="Medium" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4"
                                PointerEntered="ItemButtons_PointerEntered" PointerExited="ItemButtons_PointerExited">
                        <Button Click="MoveItem_Click" Tag="{Binding}"
                                ToolTipService.ToolTip="Move to..." Padding="8,5">
                            <FontIcon Glyph="&#xE8DE;" FontSize="14"/>
                        </Button>
                        <Button Click="MoveItemUp_Click" Tag="{Binding}"
                                ToolTipService.ToolTip="Move up" Padding="6,5">
                            <FontIcon Glyph="&#xE70E;" FontSize="12"/>
                        </Button>
                        <Button Click="MoveItemDown_Click" Tag="{Binding}"
                                ToolTipService.ToolTip="Move down" Padding="6,5">
                            <FontIcon Glyph="&#xE70D;" FontSize="12"/>
                        </Button>
                        <Button Click="EditItem_Click" Tag="{Binding}"
                                ToolTipService.ToolTip="Edit" Padding="6,5">
                            <FontIcon Glyph="&#xE70F;" FontSize="12"/>
                        </Button>
                        <Button Click="RemoveItem_Click" Tag="{Binding}"
                                ToolTipService.ToolTip="Remove" Padding="6,5">
                            <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template for column break items -->
        <DataTemplate x:Key="ColumnBreakItemTemplate">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,2"
                    Loaded="ItemCard_Loaded"
                    PointerEntered="ItemCard_PointerEntered" PointerExited="ItemCard_PointerExited">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE700;" FontSize="12" Opacity="0.3" VerticalAlignment="Center"
                              ToolTipService.ToolTip="Drag to reorder"/>
                    <FontIcon Grid.Column="1" Glyph="&#xE8C1;" FontSize="20" VerticalAlignment="Center"
                              Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                    <TextBlock Grid.Column="2" Text="Column Break" FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Opacity="0.8"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4"
                                PointerEntered="ItemButtons_PointerEntered" PointerExited="ItemButtons_PointerExited">
                        <Button Click="MoveItemUp_Click" Tag="{Binding}"
                                ToolTipService.ToolTip="Move up" Padding="6,5">
                            <FontIcon Glyph="&#xE70E;" FontSize="12"/>
                        </Button>
                        <Button Click="MoveItemDown_Click" Tag="{Binding}"
                                ToolTipService.ToolTip="Move down" Padding="6,5">
                            <FontIcon Glyph="&#xE70D;" FontSize="12"/>
                        </Button>
                        <Button Click="RemoveItem_Click" Tag="{Binding}"
                                ToolTipService.ToolTip="Remove" Padding="6,5">
                            <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template for group items (custom expand/collapse for draggability) -->
        <DataTemplate x:Key="GroupItemTemplate">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="4" Margin="0,2"
                    Loaded="ItemCard_Loaded"
                    PointerEntered="ItemCard_PointerEntered" PointerExited="ItemCard_PointerExited">
                <StackPanel Tag="GroupRoot" Loaded="GroupRoot_Loaded">
                    <Grid ColumnSpacing="8" Padding="12,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE700;" FontSize="12" Opacity="0.3" VerticalAlignment="Center"
                                  ToolTipService.ToolTip="Drag to reorder"/>
                        <Button Grid.Column="1" Click="ToggleGroupExpand_Click"
                                Padding="4" Background="Transparent" BorderThickness="0"
                                VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE70D;" FontSize="12" Opacity="0.6"/>
                        </Button>
                        <TextBlock Grid.Column="2" Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4"
                                    PointerEntered="ItemButtons_PointerEntered" PointerExited="ItemButtons_PointerExited">
                            <Button Click="MoveItemUp_Click" Tag="{Binding}"
                                    ToolTipService.ToolTip="Move up" Padding="6,5">
                                <FontIcon Glyph="&#xE70E;" FontSize="12"/>
                            </Button>
                            <Button Click="MoveItemDown_Click" Tag="{Binding}"
                                    ToolTipService.ToolTip="Move down" Padding="6,5">
                                <FontIcon Glyph="&#xE70D;" FontSize="12"/>
                            </Button>
                            <Button Click="EditItem_Click" Tag="{Binding}"
                                    ToolTipService.ToolTip="Edit" Padding="6,5">
                                <FontIcon Glyph="&#xE70F;" FontSize="12"/>
                            </Button>
                            <Button Click="RemoveItem_Click" Tag="{Binding}"
                                    ToolTipService.ToolTip="Remove" Padding="6,5">
                                <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <StackPanel Tag="GroupChildren" Margin="24,0,0,0">
                        <ListView ItemsSource="{Binding Children}"
                                  Tag="{Binding}"
                                  CanDragItems="True" AllowDrop="True"
                                  SelectionMode="None"
                                  ItemTemplateSelector="{StaticResource ItemTemplateSelector}"
                                  DragItemsStarting="GroupChildList_DragItemsStarting"
                                  DragOver="GroupChildList_DragOver"
                                  DragLeave="GroupChildList_DragLeave"
                                  Drop="GroupChildList_Drop"
                                  DragItemsCompleted="GroupChildList_DragItemsCompleted">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="12,8">
                            <Button Click="ShowAddItemToGroup_Click" Tag="{Binding}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                    <TextBlock Text="Add Item"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <pages:LauncherItemTemplateSelector x:Key="ItemTemplateSelector"
            LauncherItemTemplate="{StaticResource LauncherItemTemplate}"
            ColumnBreakItemTemplate="{StaticResource ColumnBreakItemTemplate}"
            GroupItemTemplate="{StaticResource GroupItemTemplate}"/>


    </Page.Resources>

    <!--
        Grid-rows layout (not ScrollViewer+StackPanel) so the ListView gets a bounded height
        and its internal ItemsStackPanel can virtualize — without this the ListView renders
        every container at once, causing scrolling choppiness with large lists.
    -->
    <Grid Margin="16" MaxWidth="1000" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Page header -->
        <StackPanel Grid.Row="0">
            <!-- Breadcrumb: ← Launchers › Launcher Name -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,2" VerticalAlignment="Center">
                <HyperlinkButton x:Name="BackToLaunchersButton" Padding="0,2,4,2" Click="BackToLayouts_Click">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE76B;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Launchers" VerticalAlignment="Center"/>
                    </StackPanel>
                </HyperlinkButton>
                <TextBlock Text="›" VerticalAlignment="Center" Opacity="0.4" Margin="2,1,6,0" FontSize="16"/>
                <TextBlock x:Name="LauncherNameCrumb" VerticalAlignment="Center" Opacity="0.7" FontSize="14"/>
            </StackPanel>
            <TextBlock x:Name="PageSubtitle" Text="Add, edit, or remove apps and websites from your little launcher. Drag items to reorder."
                       FontSize="14" Opacity="0.6" Margin="0,0,0,16"/>
        </StackPanel>

        <!-- Row 1: Item list — bounded height enables virtualization -->
        <ListView Grid.Row="1" x:Name="ItemsList"
                  CanDragItems="True"
                  AllowDrop="True"
                  SelectionMode="None"
                  ItemTemplateSelector="{StaticResource ItemTemplateSelector}"
                  DragItemsStarting="ItemsList_DragItemsStarting"
                  DragOver="ItemsList_DragOver"
                  DragLeave="ItemsList_DragLeave"
                  Drop="ItemsList_Drop"
                  DragItemsCompleted="ItemsList_DragItemsCompleted">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Row 2: drop zone + toolbar + backup -->
        <StackPanel Grid.Row="2">
            <Border x:Name="TopLevelDropZone"
                    AllowDrop="True"
                    Background="Transparent"
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="0" CornerRadius="4"
                    MinHeight="40" Margin="0,4,0,8"
                    Padding="12,8"
                    Visibility="Collapsed"
                    DragOver="TopLevelDropZone_DragOver"
                    Drop="TopLevelDropZone_Drop">
                <TextBlock Text="Drop here to move to top level"
                           FontSize="13" Opacity="0.6"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <Grid x:Name="AddButtonsToolbar" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8" FlowDirection="LeftToRight">
                    <Button Style="{ThemeResource AccentButtonStyle}" Click="ShowAddDialog_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock Text="Add Item"/>
                        </StackPanel>
                    </Button>
                    <Button Click="ShowAddGroupDialog_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xF168;" FontSize="14"/>
                            <TextBlock Text="Add Group"/>
                        </StackPanel>
                    </Button>
                    <Button Click="ShowAddColumnBreakDialog_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8C1;" FontSize="14"/>
                            <TextBlock Text="Add Column Break"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <TextBlock Text="Backup" FontSize="14" FontWeight="SemiBold" Margin="0,20,0,6"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Export Items..." Click="ExportItems_Click"/>
                <Button x:Name="ImportButton" Content="Import Items..." Click="ImportItems_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>