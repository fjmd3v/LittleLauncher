<Page x:Class="LittleLauncher.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
    <StackPanel MaxWidth="1000" Margin="16">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
            <Image x:Name="AppIcon" Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Text="Little Launcher" FontSize="24" FontWeight="Medium" VerticalAlignment="Center" />
            <TextBlock x:Name="VersionTextBlock" FontSize="14" FontWeight="Normal" VerticalAlignment="Bottom" Margin="10,10,4,10" Opacity="0.5" />
            <TextBlock x:Name="BuildTypeTextBlock" FontSize="14" FontWeight="Normal" VerticalAlignment="Bottom" Margin="0,10,10,10" Opacity="0.35" />
        </StackPanel>

        <!-- Update banner (hidden by default) -->
        <InfoBar x:Name="UpdateInfoBar"
                 Title="Update Available"
                 IsOpen="False"
                 IsClosable="True"
                 Severity="Informational"
                 Margin="0,8,0,0">
            <InfoBar.ActionButton>
                <Button x:Name="UpdateActionButton" Content="Download &amp; Install" Click="UpdateAction_Click" />
            </InfoBar.ActionButton>
        </InfoBar>

        <TextBlock Text="Home" FontSize="24" FontWeight="SemiBold" Margin="0,24,0,12" />

        <TextBlock Text="Dashboard" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6" />
        <Grid Margin="-4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="4" Padding="12,20" CornerRadius="4"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    PointerReleased="LauncherItems_Click"
                    PointerEntered="DashboardCard_PointerEntered" PointerExited="DashboardCard_PointerExited">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE71D;" FontSize="30" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock FontWeight="Medium" Text="Launcher Items" />
                            <TextBlock Text="Manage your shortcuts" Opacity="0.5" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                    <FontIcon Grid.Column="1" Glyph="&#xE76C;" FontSize="14" Opacity="0.3" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="4" Padding="12,20" CornerRadius="4"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    PointerReleased="SyncSettings_Click"
                    PointerEntered="DashboardCard_PointerEntered" PointerExited="DashboardCard_PointerExited">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE895;" FontSize="30" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock FontWeight="Medium" Text="Cloud Sync" />
                            <TextBlock Text="SSH/SFTP sync" Opacity="0.5" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                    <FontIcon Grid.Column="1" Glyph="&#xE76C;" FontSize="14" Opacity="0.3" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Text="Flyout Access" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,6" />

        <Border CornerRadius="4" Padding="16" Margin="0,0,0,4"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xEA8F;" Margin="0,0,16,0" />
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Show Tray Icon" FontSize="14" />
                    <TextBlock Text="Click the system tray icon to open the flyout" FontSize="12" Opacity="0.5" />
                </StackPanel>
                <ToggleSwitch x:Name="TrayIconSwitch" Grid.Column="2" HorizontalAlignment="Right" OnContent="" OffContent="" MinWidth="0" Toggled="TrayIconSwitch_Toggled" />
            </Grid>
        </Border>

        <Border CornerRadius="4" Padding="16" Margin="0,0,0,4"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE718;" Margin="0,0,16,0" />
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Pin to Taskbar" FontSize="14" />
                    <TextBlock Text="Pin a shortcut to the taskbar that opens the flyout" FontSize="12" Opacity="0.5" />
                </StackPanel>
                <Button Grid.Column="2" Content="Pin to Taskbar" Click="PinToTaskbar_Click" />
            </Grid>
        </Border>
    </StackPanel>
    </Grid>
    </ScrollViewer>
</Page>