<Page x:Class="LittleLauncher.Pages.SyncPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
    <StackPanel MaxWidth="1000" Margin="16">
        <TextBlock Text="Cloud Sync (SSH/SFTP)" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <TextBlock Text="Sync your settings to a remote server via SFTP. Uses SSH key or password authentication."
                   FontSize="14" Opacity="0.6" Margin="0,0,0,16" TextWrapping="Wrap"/>

        <!-- Connection settings -->
        <TextBlock Text="Connection" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE770;" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Host" FontSize="14" VerticalAlignment="Center"/>
                <TextBox Grid.Column="2" Text="{Binding SftpHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="e.g. 192.168.1.100" Width="200"/>
            </Grid>
        </Border>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE71B;" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Port" FontSize="14" VerticalAlignment="Center"/>
                <NumberBox Grid.Column="2" x:Name="PortBox" Value="{Binding SftpPort, Mode=TwoWay}" Minimum="1" Maximum="65535" SpinButtonPlacementMode="Hidden" Width="90"/>
            </Grid>
        </Border>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE77B;" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Username" FontSize="14" VerticalAlignment="Center"/>
                <TextBox Grid.Column="2" Text="{Binding SftpUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Default: Windows user" Width="200"/>
            </Grid>
        </Border>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE8D7;" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Private Key Path" FontSize="14"/>
                    <TextBlock Text="Auto-detected from ~/.ssh/ if empty" FontSize="12" Opacity="0.5"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBox Text="{Binding SftpPrivateKeyPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="~/.ssh/id_rsa" Width="200" Margin="0,0,8,0"/>
                    <Button Content="Browse..." Click="BrowseKey_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE8B7;" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Remote Path" FontSize="14"/>
                    <TextBlock Text="Directory on the server to store settings" FontSize="12" Opacity="0.5"/>
                </StackPanel>
                <TextBox Grid.Column="2" Text="{Binding SftpRemotePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="250"/>
            </Grid>
        </Border>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE72C;" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Auto Sync" FontSize="14"/>
                    <TextBlock Text="Sync launcher items on startup, on change, and periodically" FontSize="12" Opacity="0.5"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="2" OnContent="" OffContent="" MinWidth="0" IsOn="{Binding SftpAutoSync, Mode=TwoWay}"/>
            </Grid>
        </Border>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE823;" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Sync Interval (minutes)" FontSize="14"/>
                    <TextBlock Text="How often to download launcher items from the server" FontSize="12" Opacity="0.5"/>
                </StackPanel>
                <NumberBox Grid.Column="2" Value="{Binding SftpAutoSyncInterval, Mode=TwoWay}" Minimum="1" Maximum="1440" SpinButtonPlacementMode="Inline" Width="130"/>
            </Grid>
        </Border>

        <!-- Actions -->
        <TextBlock Text="Actions" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,6"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" Spacing="8">
            <Button Content="Test Connection" Click="TestConnection_Click"/>
            <Button Content="Upload Launcher Items" Click="Upload_Click"/>
            <Button Content="Download Launcher Items" Click="Download_Click"/>
        </StackPanel>

        <!-- Status display -->
        <InfoBar x:Name="StatusBar" IsOpen="False" IsClosable="True" Margin="0,0,0,8"/>

        <TextBlock Text="Connection Profile" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,6"/>
        <TextBlock Text="Export or import just the SSH connection settings for use on other machines."
                   FontSize="13" Opacity="0.6" Margin="0,0,0,8" TextWrapping="Wrap"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" Spacing="8">
            <Button Content="Export Connection..." Click="ExportSshConfig_Click"/>
            <Button Content="Import Connection..." Click="ImportSshConfig_Click"/>
        </StackPanel>

        <!-- Password prompt (shown when needed) -->
        <Border x:Name="PasswordCard"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE8D7;" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Password / Key Passphrase" FontSize="14" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <PasswordBox x:Name="PasswordBox" Width="200" Margin="0,0,8,0"/>
                    <Button Content="OK" Click="PasswordOk_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </StackPanel>
    </Grid>
    </ScrollViewer>
</Page>