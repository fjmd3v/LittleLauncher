<Page x:Class="LittleLauncher.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
    <StackPanel MaxWidth="1000" Margin="16">
        <TextBlock Text="About" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE946;" FontSize="24" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Little Launcher" FontSize="16" FontWeight="Medium"/>
                    <TextBlock Text="A customizable application and website launcher that lives in your Windows taskbar."
                               FontSize="13" Opacity="0.6" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE943;" FontSize="24" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Built With" FontSize="14" FontWeight="Medium"/>
                    <TextBlock Text="WinUI 3 · .NET 10 · Windows App SDK · CommunityToolkit.Mvvm · SSH.NET · NLog"
                               FontSize="12" Opacity="0.5"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE12B;" FontSize="24" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Source Code" FontSize="14" FontWeight="Medium"/>
                    <TextBlock Text="View the project on GitHub" FontSize="12" Opacity="0.5"/>
                </StackPanel>
                <HyperlinkButton Grid.Column="2" Content="GitHub Repository"
                                 NavigateUri="https://github.com/RyanEwen/LittleLauncher" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE895;" FontSize="24" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Updates" FontSize="14" FontWeight="Medium"/>
                    <TextBlock x:Name="UpdateStatusText" Text="Click to check for updates" FontSize="12" Opacity="0.5"/>
                </StackPanel>
                <Button x:Name="CheckUpdateButton" Grid.Column="2" Content="Check for Updates" Click="CheckForUpdates_Click" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </StackPanel>
    </Grid>
    </ScrollViewer>
</Page>