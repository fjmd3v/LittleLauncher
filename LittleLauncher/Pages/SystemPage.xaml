<Page x:Class="LittleLauncher.Pages.SystemPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
    <StackPanel MaxWidth="1000" Margin="16">
        <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,24"/>

        <!-- Appearance -->
        <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE790;" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="App Theme" FontSize="14" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="2" SelectedIndex="{Binding AppTheme, Mode=TwoWay}">
                    <ComboBoxItem Content="System Default"/>
                    <ComboBoxItem Content="Light"/>
                    <ComboBoxItem Content="Dark"/>
                </ComboBox>
            </Grid>
        </Border>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xEB9F;" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="App Icon" FontSize="14"/>
                    <TextBlock Text="Icon used in the tray, taskbar, and shortcuts" FontSize="12" Opacity="0.5"/>
                </StackPanel>
                <ComboBox x:Name="TrayIconModeCombo" Grid.Column="2" MinWidth="160"
                          SelectedIndex="{Binding TrayIconMode, Mode=TwoWay}" SelectionChanged="TrayIconModeCombo_SelectionChanged">
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Image x:Name="IconPreviewBlue" Width="20" Height="20"/>
                            <TextBlock Text="Blue" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Image x:Name="IconPreviewGreen" Width="20" Height="20"/>
                            <TextBlock Text="Green" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Image x:Name="IconPreviewTeal" Width="20" Height="20"/>
                            <TextBlock Text="Teal" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Image x:Name="IconPreviewRed" Width="20" Height="20"/>
                            <TextBlock Text="Red" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Image x:Name="IconPreviewOrange" Width="20" Height="20"/>
                            <TextBlock Text="Orange" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Image x:Name="IconPreviewPurple" Width="20" Height="20"/>
                            <TextBlock Text="Purple" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE840;" FontSize="16"/>
                            <TextBlock Text="Pin" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE734;" FontSize="16"/>
                            <TextBlock Text="Star" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEB51;" FontSize="16"/>
                            <TextBlock Text="Heart" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE945;" FontSize="16"/>
                            <TextBlock Text="Lightning" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE721;" FontSize="16"/>
                            <TextBlock Text="Search" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE774;" FontSize="16"/>
                            <TextBlock Text="Globe" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem Content="Custom..."/>
                </ComboBox>
            </Grid>
        </Border>

        <Border x:Name="CustomIconCard" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xEB9F;" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Custom Icon" FontSize="14"/>
                    <TextBlock x:Name="CustomIconPathText" Text="No file selected" FontSize="12" Opacity="0.5"
                               TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                </StackPanel>
                <Button Grid.Column="2" Content="Browse..." Click="BrowseCustomIcon_Click"/>
            </Grid>
        </Border>

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE8FC;" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Launch on Startup" FontSize="14"/>
                    <TextBlock Text="Start minimized to the system tray" FontSize="12" Opacity="0.5"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="2" x:Name="StartupSwitch" OnContent="" OffContent="" MinWidth="0" Toggled="StartupSwitch_Toggled" IsOn="{Binding Startup, Mode=TwoWay}"/>
            </Grid>
        </Border>

        <!-- Backup and Restore -->
        <TextBlock Text="Backup &amp; Restore" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,6"/>
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,60">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE777;" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Export / Import All Settings" FontSize="14" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Content="Export All Settings..." Click="ExportButton_Click"/>
                    <Button Content="Import All Settings..." Click="ImportButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </StackPanel>
    </Grid>
    </ScrollViewer>
</Page>