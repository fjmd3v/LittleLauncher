<Window
    x:Class="LittleLauncher.Windows.FlyoutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LittleLauncher.Windows">
    <Grid
        x:Name="RootGrid"
        MinHeight="80"
        Background="Transparent"
        Padding="0">

        <Grid.Resources>
            <local:IconPathToImageConverter x:Key="IconPathToImage" />
            <local:IconPathToVisibilityConverter x:Key="IconPathToVisibility" />
            <local:IsFluentGlyphConverter x:Key="IsFluentGlyph" />
            <local:IconColorToBrushConverter x:Key="IconColorToBrush" />

            <local:FlyoutItemTemplateSelector
                x:Key="ItemTemplateSelector"
                GroupTemplate="{StaticResource GroupTemplate}"
                ItemTemplate="{StaticResource LauncherItemTemplate}" />

            <!-- Group heading row -->
            <DataTemplate x:Key="GroupTemplate">
                <Grid Margin="0,6,0,0"
                      HorizontalAlignment="Stretch">
                    <TextBlock
                        Text="{Binding Name}"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Opacity="0.7"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        VerticalAlignment="Center"
                        TextWrapping="NoWrap"
                        TextTrimming="CharacterEllipsis" />
                </Grid>
            </DataTemplate>

            <!-- Container style for launcher items (with hover effect) -->
            <Style x:Key="LauncherItemContainerStyle" TargetType="ListViewItem">
                <Setter Property="IsTabStop" Value="False" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled" />
                                        <VisualState x:Name="Selected" />
                                        <VisualState x:Name="PointerOverSelected">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="PressedSelected">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Border
                                    x:Name="BackgroundBorder"
                                    CornerRadius="6"
                                    Background="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                    <ContentPresenter
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                        ContentTransitions="{TemplateBinding ContentTransitions}"
                                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Container style for group headers (non-interactive) -->
            <Style x:Key="GroupItemContainerStyle" TargetType="ListViewItem">
                <Setter Property="IsTabStop" Value="False" />
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Padding" Value="8,8,8,2" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Border Padding="{TemplateBinding Padding}">
                                <ContentPresenter
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <local:FlyoutItemContainerStyleSelector
                x:Key="ItemContainerStyleSelector"
                GroupStyle="{StaticResource GroupItemContainerStyle}"
                ItemStyle="{StaticResource LauncherItemContainerStyle}" />

            <!-- Launcher item row -->
            <DataTemplate x:Key="LauncherItemTemplate">
                <Grid HorizontalAlignment="Stretch" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Icon image (shown when IconPath file exists) -->
                    <Image
                        Grid.Column="0"
                        Source="{Binding IconPath, Converter={StaticResource IconPathToImage}}"
                        Visibility="{Binding IconPath, Converter={StaticResource IconPathToVisibility}}"
                        Width="20" Height="20"
                        VerticalAlignment="Center" />

                    <!-- Glyph fallback (shown when no IconPath) -->
                    <Grid Grid.Column="0"
                          Visibility="{Binding IconPath, Converter={StaticResource IconPathToVisibility}, ConverterParameter=invert}">
                        <!-- Segoe Fluent Icons glyph -->
                        <FontIcon
                            Glyph="{Binding IconGlyph}"
                            Visibility="{Binding IconGlyph, Converter={StaticResource IsFluentGlyph}}"
                            Foreground="{Binding IconColor, Converter={StaticResource IconColorToBrush}}"
                            FontSize="18"
                            VerticalAlignment="Center" />
                        <!-- Emoji glyph -->
                        <TextBlock
                            Text="{Binding IconGlyph}"
                            Visibility="{Binding IconGlyph, Converter={StaticResource IsFluentGlyph}, ConverterParameter=invert}"
                            Foreground="{Binding IconColor, Converter={StaticResource IconColorToBrush}}"
                            FontSize="18"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center" />
                    </Grid>

                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding Name}"
                        FontSize="13"
                        VerticalAlignment="Center"
                        TextWrapping="NoWrap"
                        TextTrimming="CharacterEllipsis" />
                </Grid>
            </DataTemplate>
        </Grid.Resources>

        <Grid.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem x:Name="ContextEditLauncherSettings" Text="Edit Launcher Settings" Click="ContextEditLauncherSettings_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="ContextEditLauncherItems" Text="Edit Launcher Items" Click="ContextEditLauncherItems_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE70F;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="ContextSettingsItem" Text="Settings" Click="ContextSettingsItem_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>
        </Grid.ContextFlyout>

        <StackPanel>
            <TextBlock x:Name="LauncherTitle"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Opacity="0.7"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       TextAlignment="Center"
                       HorizontalAlignment="Stretch"
                       Margin="16,8,16,0"
                       Visibility="Collapsed" />
            <StackPanel x:Name="ColumnsPanel" Orientation="Horizontal" />
        </StackPanel>
    </Grid>
</Window>
