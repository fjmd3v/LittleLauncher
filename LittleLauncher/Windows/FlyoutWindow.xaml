<Window
    x:Class="LittleLauncher.Windows.FlyoutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LittleLauncher.Windows">
    <Grid
        x:Name="RootGrid"
        MinHeight="0"
        Background="Transparent"
        Padding="0">

        <Grid.Resources>
            <local:IconPathToImageConverter x:Key="IconPathToImage" />
            <local:IconPathToVisibilityConverter x:Key="IconPathToVisibility" />
            <local:IsFluentGlyphConverter x:Key="IsFluentGlyph" />
            <local:IconColorToBrushConverter x:Key="IconColorToBrush" />

            <local:FlyoutItemTemplateSelector
                x:Key="ListItemTemplateSelector"
                GroupTemplate="{StaticResource ListGroupTemplate}"
                ItemTemplate="{StaticResource LauncherItemTemplate}" />

            <local:FlyoutItemTemplateSelector
                x:Key="IconItemTemplateSelector"
                GroupTemplate="{StaticResource IconGroupTemplate}"
                SyntheticGroupTemplate="{StaticResource IconSyntheticGroupTemplate}"
                ItemTemplate="{StaticResource IconItemTemplate}" />

            <local:FlyoutItemTemplateSelector
                x:Key="SmallIconItemTemplateSelector"
                GroupTemplate="{StaticResource SmallIconGroupTemplate}"
                SyntheticGroupTemplate="{StaticResource SmallIconSyntheticGroupTemplate}"
                ItemTemplate="{StaticResource SmallIconItemTemplate}" />

            <DataTemplate x:Key="ListGroupTemplate">
                <StackPanel Margin="0"
                            HorizontalAlignment="Stretch">
                    <Grid Margin="8,4,8,4"
                          HorizontalAlignment="Stretch"
                                                    ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                   Text="{Binding Name}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Opacity="0.7"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>

                    <ListView ItemsSource="{Binding Children}"
                              Tag="{Binding}"
                              HorizontalAlignment="Stretch"
                              CanDragItems="True"
                              AllowDrop="True"
                              Loaded="ListGroupChildList_Loaded"
                              IsItemClickEnabled="True"
                              SelectionMode="None"
                              MinHeight="0"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ItemTemplate="{StaticResource LauncherItemTemplate}"
                              ItemContainerStyle="{StaticResource LauncherItemContainerStyle}"
                              ItemClick="ItemsListControl_ItemClick"
                              RightTapped="ItemsListControl_RightTapped"
                              DragItemsStarting="GroupChildList_DragItemsStarting"
                              DragOver="GroupChildList_DragOver"
                              DragLeave="GroupChildList_DragLeave"
                              Drop="GroupChildList_Drop"
                              DragItemsCompleted="GroupChildList_DragItemsCompleted" />
                </StackPanel>
            </DataTemplate>

            <!-- Container style for launcher items (with hover effect) -->
            <Style x:Key="LauncherItemContainerStyle" TargetType="ListViewItem">
                <Setter Property="IsTabStop" Value="False" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Grid HorizontalAlignment="Stretch">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled" />
                                        <VisualState x:Name="Selected" />
                                        <VisualState x:Name="PointerOverSelected">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="PressedSelected">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Border
                                    x:Name="BackgroundBorder"
                                    CornerRadius="6"
                                    Background="Transparent"
                                    HorizontalAlignment="Stretch"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                    <ContentPresenter
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                        ContentTransitions="{TemplateBinding ContentTransitions}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Container style for group headers (non-interactive) -->
            <Style x:Key="GroupItemContainerStyle" TargetType="ListViewItem">
                <Setter Property="IsTabStop" Value="False" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Border Padding="{TemplateBinding Padding}"
                                    HorizontalAlignment="Stretch"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <local:FlyoutItemContainerStyleSelector
                x:Key="ItemContainerStyleSelector"
                GroupStyle="{StaticResource GroupItemContainerStyle}"
                ItemStyle="{StaticResource LauncherItemContainerStyle}" />

            <Style x:Key="IconItemContainerStyle" TargetType="ListViewItem">
                <Setter Property="IsTabStop" Value="False" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled" />
                                        <VisualState x:Name="Selected" />
                                        <VisualState x:Name="PointerOverSelected">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="PressedSelected">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <Border x:Name="BackgroundBorder"
                                        Background="Transparent"
                                    CornerRadius="6"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Launcher item row -->
            <DataTemplate x:Key="LauncherItemTemplate">
                <Grid HorizontalAlignment="Stretch" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Icon image (shown when IconPath file exists) -->
                    <Image
                        Grid.Column="0"
                        Source="{Binding IconPath, Converter={StaticResource IconPathToImage}, ConverterParameter=20}"
                        Visibility="{Binding IconPath, Converter={StaticResource IconPathToVisibility}}"
                        Width="20" Height="20"
                        VerticalAlignment="Center" />

                    <!-- Glyph fallback (shown when no IconPath) -->
                    <Grid Grid.Column="0"
                          Visibility="{Binding IconPath, Converter={StaticResource IconPathToVisibility}, ConverterParameter=invert}">
                        <!-- Segoe Fluent Icons glyph -->
                        <FontIcon
                            Glyph="{Binding IconGlyph}"
                            Visibility="{Binding IconGlyph, Converter={StaticResource IsFluentGlyph}}"
                            Foreground="{Binding IconColor, Converter={StaticResource IconColorToBrush}}"
                            FontSize="18"
                            VerticalAlignment="Center" />
                        <!-- Emoji glyph -->
                        <TextBlock
                            Text="{Binding IconGlyph}"
                            Visibility="{Binding IconGlyph, Converter={StaticResource IsFluentGlyph}, ConverterParameter=invert}"
                            Foreground="{Binding IconColor, Converter={StaticResource IconColorToBrush}}"
                            FontSize="18"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center" />
                    </Grid>

                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding Name}"
                        FontSize="13"
                        VerticalAlignment="Center"
                        TextWrapping="NoWrap"
                        TextTrimming="CharacterEllipsis" />
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="IconItemTemplate">
                <Grid Width="80" Height="84">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48" />
                        <RowDefinition Height="36" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                                                <Image Source="{Binding IconPath, Converter={StaticResource IconPathToImage}, ConverterParameter=32}"
                               Visibility="{Binding IconPath, Converter={StaticResource IconPathToVisibility}}"
                               Width="32"
                               Height="32" />

                        <Grid Visibility="{Binding IconPath, Converter={StaticResource IconPathToVisibility}, ConverterParameter=invert}">
                            <FontIcon Glyph="{Binding IconGlyph}"
                                      Visibility="{Binding IconGlyph, Converter={StaticResource IsFluentGlyph}}"
                                      Foreground="{Binding IconColor, Converter={StaticResource IconColorToBrush}}"
                                      FontSize="28" />

                            <TextBlock Text="{Binding IconGlyph}"
                                       Visibility="{Binding IconGlyph, Converter={StaticResource IsFluentGlyph}, ConverterParameter=invert}"
                                       Foreground="{Binding IconColor, Converter={StaticResource IconColorToBrush}}"
                                       FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="{Binding Name}"
                               FontSize="11"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Center"
                               MaxWidth="72"
                               Margin="0,2,0,0" />
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="SmallIconItemTemplate">
                <Grid Width="40" Height="40">
                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                                                <Image Source="{Binding IconPath, Converter={StaticResource IconPathToImage}, ConverterParameter=20}"
                               Visibility="{Binding IconPath, Converter={StaticResource IconPathToVisibility}}"
                               Width="20"
                               Height="20" />

                        <Grid Visibility="{Binding IconPath, Converter={StaticResource IconPathToVisibility}, ConverterParameter=invert}">
                            <FontIcon Glyph="{Binding IconGlyph}"
                                      Visibility="{Binding IconGlyph, Converter={StaticResource IsFluentGlyph}}"
                                      Foreground="{Binding IconColor, Converter={StaticResource IconColorToBrush}}"
                                      FontSize="18" />

                            <TextBlock Text="{Binding IconGlyph}"
                                       Visibility="{Binding IconGlyph, Converter={StaticResource IsFluentGlyph}, ConverterParameter=invert}"
                                       Foreground="{Binding IconColor, Converter={StaticResource IconColorToBrush}}"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="IconGroupTemplate">
                <StackPanel Margin="0">
                    <Grid Margin="8,4,8,4"
                          HorizontalAlignment="Stretch"
                          ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding Name}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Opacity="0.7"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                 HorizontalAlignment="Center"
                                 TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>

                    <ListView ItemsSource="{Binding Children}"
                              Tag="{Binding}"
                              HorizontalAlignment="Center"
                              CanDragItems="True"
                              AllowDrop="True"
                              IsItemClickEnabled="True"
                              SelectionMode="None"
                              MinHeight="0"
                              Loaded="IconGroupChildList_Loaded"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ItemTemplate="{StaticResource IconItemTemplate}"
                              ItemContainerStyle="{StaticResource IconItemContainerStyle}"
                              ItemClick="ItemsListControl_ItemClick"
                              RightTapped="ItemsListControl_RightTapped"
                              DragItemsStarting="GroupChildList_DragItemsStarting"
                              DragOver="GroupChildList_DragOver"
                              DragLeave="GroupChildList_DragLeave"
                              Drop="GroupChildList_Drop"
                              DragItemsCompleted="GroupChildList_DragItemsCompleted">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                    </ListView>
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="IconSyntheticGroupTemplate">
                <ListView ItemsSource="{Binding Children}"
                          Tag="{Binding}"
                          CanDragItems="True"
                          AllowDrop="True"
                          IsItemClickEnabled="True"
                          SelectionMode="None"
                          MinHeight="0"
                          Loaded="IconGroupChildList_Loaded"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ItemTemplate="{StaticResource IconItemTemplate}"
                          ItemContainerStyle="{StaticResource IconItemContainerStyle}"
                          ItemClick="ItemsListControl_ItemClick"
                          RightTapped="ItemsListControl_RightTapped"
                          DragItemsStarting="GroupChildList_DragItemsStarting"
                          DragOver="GroupChildList_DragOver"
                          DragLeave="GroupChildList_DragLeave"
                          Drop="GroupChildList_Drop"
                          DragItemsCompleted="GroupChildList_DragItemsCompleted">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                </ListView>
            </DataTemplate>

            <DataTemplate x:Key="SmallIconGroupTemplate">
                <StackPanel Margin="0">
                    <Grid Margin="8,4,8,4"
                          HorizontalAlignment="Stretch"
                          ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding Name}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Opacity="0.7"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>

                    <ListView ItemsSource="{Binding Children}"
                              Tag="{Binding}"
                              HorizontalAlignment="Center"
                              CanDragItems="True"
                              AllowDrop="True"
                              IsItemClickEnabled="True"
                              SelectionMode="None"
                              MinHeight="0"
                              Loaded="IconGroupChildList_Loaded"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ItemTemplate="{StaticResource SmallIconItemTemplate}"
                              ItemContainerStyle="{StaticResource IconItemContainerStyle}"
                              ItemClick="ItemsListControl_ItemClick"
                              RightTapped="ItemsListControl_RightTapped"
                              DragItemsStarting="GroupChildList_DragItemsStarting"
                              DragOver="GroupChildList_DragOver"
                              DragLeave="GroupChildList_DragLeave"
                              Drop="GroupChildList_Drop"
                              DragItemsCompleted="GroupChildList_DragItemsCompleted">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                    </ListView>
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="SmallIconSyntheticGroupTemplate">
                <ListView ItemsSource="{Binding Children}"
                          Tag="{Binding}"
                          CanDragItems="True"
                          AllowDrop="True"
                          IsItemClickEnabled="True"
                          SelectionMode="None"
                          MinHeight="0"
                          Loaded="IconGroupChildList_Loaded"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ItemTemplate="{StaticResource SmallIconItemTemplate}"
                          ItemContainerStyle="{StaticResource IconItemContainerStyle}"
                          ItemClick="ItemsListControl_ItemClick"
                          RightTapped="ItemsListControl_RightTapped"
                          DragItemsStarting="GroupChildList_DragItemsStarting"
                          DragOver="GroupChildList_DragOver"
                          DragLeave="GroupChildList_DragLeave"
                          Drop="GroupChildList_Drop"
                          DragItemsCompleted="GroupChildList_DragItemsCompleted">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                </ListView>
            </DataTemplate>
        </Grid.Resources>

        <Grid.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem x:Name="ContextEditLauncherSettings" Text="Edit Launcher Settings" Click="ContextEditLauncherSettings_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="ContextEditLauncherItems" Text="Edit Launcher Items" Click="ContextEditLauncherItems_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE70F;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="ContextSettingsItem" Text="Settings" Click="ContextSettingsItem_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>
        </Grid.ContextFlyout>

        <StackPanel x:Name="ContentStack" VerticalAlignment="Top" Margin="8">
            <TextBlock x:Name="LauncherTitle"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Opacity="0.7"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       TextAlignment="Center"
                       HorizontalAlignment="Stretch"
                       Margin="8,4,8,8"
                       Visibility="Collapsed" />
            <StackPanel x:Name="ColumnsPanel" Orientation="Horizontal" />
        </StackPanel>
    </Grid>
</Window>
